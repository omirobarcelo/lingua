# Node environment
NODE_ENV=development

# Local PostgreSQL (Docker)
DATABASE_URL=postgres://lingua:lingua_dev_password@localhost:5432/lingua

# Neon connection string (only needed for db:pull script)
# NEON_DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# PostHog analytics (set to true to enable)
PUBLIC_POSTHOG_ENABLED=false
PUBLIC_POSTHOG_PROJECT_TOKEN=your_posthog_project_token
PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# Admin panel
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
