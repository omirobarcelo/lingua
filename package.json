{
  "name": "lingua",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "staging": "vite dev --mode staging",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:setup:fts": "tsx --env-file .env src/lib/server/db/run-setup.ts fts",
    "db:setup:trigger": "tsx --env-file .env src/lib/server/db/run-setup.ts trigger",
    "db:seed": "tsx --env-file .env src/lib/server/db/seed.ts",
    "db:pull": "tsx --env-file .env scripts/pull-neon.ts"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.55.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/sharp": "^0.31.1",
    "@vite-pwa/sveltekit": "^1.1.0",
    "drizzle-kit": "^0.31.8",
    "sharp": "^0.34.5",
    "svelte": "^5.48.3",
    "svelte-check": "^4.2.5",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^8.0.2"
  },
  "type": "module",
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "drizzle-orm": "^0.45.1",
    "node-html-parser": "^7.1.0",
    "postgres": "^3.4.5",
    "posthog-js": "^1.363.3",
    "posthog-node": "^5.21.2"
  }
}
