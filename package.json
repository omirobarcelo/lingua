{
  "name": "lingua",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio",
    "db:generate": "drizzle-kit generate",
    "db:setup:fts": "tsx --env-file .env src/lib/server/db/run-setup.ts fts",
    "db:setup:trigger": "tsx --env-file .env src/lib/server/db/run-setup.ts trigger"
  },
  "devDependencies": {
    "@sveltejs/adapter-vercel": "^6.3.1",
    "@sveltejs/kit": "^2.50.1",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/vite": "^4.2.1",
    "@types/node": "^25.5.0",
    "drizzle-kit": "^0.31.8",
    "svelte": "^5.48.3",
    "svelte-check": "^4.2.5",
    "tailwindcss": "^4.2.1",
    "tslib": "^2.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3",
    "vite": "^6.4.1"
  },
  "type": "module",
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "postgres": "^3.4.5"
  }
}
